### 8. 🎨 UI/UX Polish
- Add **skeleton loaders** for suspense boundaries (currently blank during fetch)
- Implement **optimistic updates** for likes/cart (show immediate feedback)
- Add **toast persistence** for critical actions (e.g., "Item added — view cart")

```tsx
// Optimistic like toggle
const likeM = useMutation({
  onMutate: async (id) => {
    await qc.cancelQueries({ queryKey: ['landing'] });
    const previous = qc.getQueryData(['landing']);
    qc.setQueryData(['landing'], (old: any) => ({
      ...old,
      featured: old.featured.map((item: any) => 
        item.id === id ? { ...item, likes: item.likes + 1 } : item
      )
    }));
    return { previous };
  },
  onError: (err, id, ctx) => {
    qc.setQueryData(['landing'], ctx.previous);
    toast.error("Failed to like item");
  }
});
```

